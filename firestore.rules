rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validations
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'createdAt'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.email is string && data.email.size() <= 128
        && data.role in ['Admin', 'Sales Manager', 'Sales Executive']
        && data.createdAt is string;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'company', 'budget', 'status', 'priority', 'ownerId'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.email is string && data.email.size() <= 128
        && data.company is string && data.company.size() <= 128
        && data.budget is number
        && data.status in ['New', 'Contacted', 'Qualified', 'Lost']
        && data.priority in ['Low', 'Medium', 'High', 'Urgent']
        && data.ownerId is string && data.ownerId.size() <= 128;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'company', 'status', 'ownerId'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.email is string && data.email.size() <= 128
        && data.company is string && data.company.size() <= 128
        && data.status in ['Active', 'Inactive', 'Churned']
        && data.ownerId is string && data.ownerId.size() <= 128;
    }

    function isValidOpportunity(data) {
      return data.keys().hasAll(['id', 'name', 'company', 'stage', 'revenue', 'probability'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.company is string && data.company.size() <= 128
        && data.stage in ['Discovery', 'Proposal', 'Negotiation', 'Contracting', 'Closed Won', 'Closed Lost']
        && data.revenue is number && data.revenue >= 0
        && data.probability is number && data.probability >= 0 && data.probability <= 100;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'status', 'priority', 'ownerId'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.status in ['Pending', 'Completed']
        && data.priority in ['Low', 'Medium', 'High']
        && data.ownerId is string && data.ownerId.size() <= 128;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'message', 'read', 'type'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.read is bool
        && data.type in ['Meeting', 'Task', 'Lead', 'Deal', 'System'];
    }

    // Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.id == request.auth.uid;
      allow create, update: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow delete: if isSignedIn() && isOwner(userId);
    }

    match /leads/{leadId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidLead(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidLead(incoming()) && (
        existing().ownerId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priority', 'score', 'scoreExplanation', 'buyingIntent', 'painPoints', 'urgency', 'budgetLevel', 'recommendation', 'nextAction'])
      );
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid);
    }

    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidCustomer(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidCustomer(incoming()) && (
        existing().ownerId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid);
    }

    match /opportunities/{oppId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidOpportunity(incoming());
      allow update: if isSignedIn() && isValidOpportunity(incoming());
      allow delete: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidTask(incoming()) && (
        existing().ownerId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidNotification(incoming()) && (
        existing().userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['read'])
      );
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid);
    }
  }
}
